# Pack / API env (host-agnostic)

# Data root (optional). Default: existing ~/.hermes if meme-packs exists, else ~/.agent-expression
# MEME_HOME=~/.agent-expression
# AGENT_EXPRESSION_HOME=~/.agent-expression

# Pack root or id
# MEME_PACK=/absolute/path/to/pack
# MEME_PACK_ID=official-001

# Hermes aliases (still supported)
# HERMES_HOME=~/.hermes
# HERMES_MEME_PACK_ID=official-001
# HERMES_MEME_PACK=/absolute/path/to/pack

# --- Optional: vector search (Zhipu embedding-3 or OpenAI-compatible) ---
ZHIPU_API_KEY=
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# Or: EMBEDDING_API_KEY=  EMBEDDING_BASE_URL=  EMBEDDING_MODEL=

# --- Optional: vision caption / classify (OpenAI-compatible) ---
# VISION_API_KEY=
# VISION_BASE_URL=
# VISION_MODEL=
# ARK_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
